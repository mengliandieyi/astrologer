PORT=3001

# Storage mode: sqlite | postgres | file
#
# 登录注册 + 历史盘面建议使用 mysql（线上可改为 mysql；本地可先用 sqlite）
STORAGE_MODE=sqlite

# Optional: set to enable PostgreSQL storage mode.
# Example: postgres://postgres:postgres@127.0.0.1:5432/astrologer
DATABASE_URL=
PGSSL=false

# MySQL（当 STORAGE_MODE=mysql 时必填；会自动建表：users/profiles/charts/events/ai_reading_cache）
# Example: mysql://user:pass@127.0.0.1:3306/astrologer?charset=utf8mb4&timezone=Z
MYSQL_URL=

# Auth（JWT secret 必填；建议至少 32 字符）
AUTH_JWT_SECRET=

# Optional: protect admin APIs when exposed publicly.
# If empty, /api/admin/* remains open.
ADMIN_TOKEN=

# SMTP（用于邮箱找回密码）
# 推荐使用企业邮箱或云邮件推送服务的 SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional: Alibaba Tongyi (Qwen) AI reading
ALI_API_KEY=
ALI_MODEL=qwen3-max
ALI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional: Tongyi Wanxiang (Wanx) text-to-image
ALI_WANX_MODEL=wanx-v1

# Tushare（A股行情/财务数据）
TUSHARE_TOKEN=

# 可选：资研「热点新闻」RSS 源。留空则使用内置默认（华尔街见闻 + 中新网财经）。
# 格式：每条「显示名|RSS_URL」；也可只写 RSS_URL（显示名取域名）。多条用英文逗号或换行分隔。
# STOCK_NEWS_FEEDS=https://dedicated.wallstreetcn.com/rss.xml

# 和风天气（逐日天气/预报）
# 兼容两种鉴权方式：旧版 key 或新版 JWT Bearer（推荐用 Bearer）
QWEATHER_KEY=
QWEATHER_API_HOST=https://api.qweather.com
QWEATHER_BEARER_TOKEN=

# 高德地图（用于查真实酒店 POI；Web Service Key）
AMAP_WEB_KEY=
